{
  "$schema": "https://schema.railpack.com",
  "provider": "rust",
  "packages": {
    "rust": "1.89"
  },
  "buildAptPackages": [
    "pkg-config",
    "libssl-dev",
    "curl"
  ],
  "steps": {
    "build": {
      "commands": [
        "cargo build --release --workspace",
        "mkdir -p bin",
        "cp target/release/tass bin/tass",
        "cp target/release/tass-codegen bin/tass-codegen",
        "cp target/release/tass-listen bin/tass-listen",
        "cp target/release/tass-validate bin/tass-validate",
        "cp target/release/tass-web bin/tass-web",
        "curl -fsSL https://pkgs.tailscale.com/stable/tailscale_1.98.8_amd64.tgz | tar xz",
        "cp tailscale_1.98.8_amd64/tailscale bin/tailscale",
        "cp tailscale_1.98.8_amd64/tailscaled bin/tailscaled"
      ]
    }
  },
  "deploy": {
    "inputs": [
      {
        "step": "build",
        "include": ["bin/tass-web", "bin/tailscale", "bin/tailscaled"]
      },
      {
        "local": true,
        "include": ["entrypoint.sh"]
      }
    ],
    "aptPackages": [
      "ca-certificates"
    ],
    "startCommand": "./entrypoint.sh"
  }
}
